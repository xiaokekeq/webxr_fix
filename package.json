{
  "name": "dam-patrol-h5",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:dam": "vite --config vite.config.dam.ts",
    "dev:water": "vite --config vite.config.water-network.ts",
    "typecheck:dam": "vue-tsc -p tsconfig.dam.json --noEmit",
    "typecheck:water": "vue-tsc -p tsconfig.water-network.json --noEmit",
    "typecheck:test": "vue-tsc -p tsconfig.test.json --noEmit",
    "typecheck": "npm run typecheck:dam && npm run typecheck:water && npm run typecheck:test",
    "build:dam": "npm run typecheck:dam && vite build --config vite.config.dam.ts",
    "build:water": "npm run typecheck:water && vite build --config vite.config.water-network.ts",
    "build": "npm run build:dam && npm run build:water",
    "test": "vitest run",
    "preview:dam": "vite preview --config vite.config.dam.ts",
    "preview:water": "vite preview --config vite.config.water-network.ts"
  },
  "dependencies": {
    "echarts": "^5.5.0",
    "pinia": "^2.1.0",
    "three": "0.185.1",
    "vant": "^4.8.0",
    "vue": "^3.4.0",
    "vue-echarts": "^6.6.0",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@types/three": "0.185.1",
    "@vant/auto-import-resolver": "^1.2.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "typescript": "^5.3.0",
    "unplugin-auto-import": "^0.17.0",
    "unplugin-vue-components": "^0.26.0",
    "vite": "^5.1.0",
    "vitest": "^2.1.9",
    "vue-tsc": "^2.0.0"
  }
}
